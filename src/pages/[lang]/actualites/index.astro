---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import PostCard from '../../../components/PostCard.astro';
import { localeFromParam, localeParams, useTranslations } from '../../../i18n/index.ts';
import { getLocalized } from '../../../lib/content.ts';

export const getStaticPaths = localeParams;

const lang = localeFromParam(Astro.params.lang);
const t = useTranslations(lang);
const posts = await getLocalized('posts', lang);
---

<BaseLayout title={t('news.title')} description={t('news.description')}>
  <PageHeader title={t('news.title')} intro={t('news.intro')} />

  <section class="section">
    <div class="container">
      <div class="grid">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--sp-5);
  }
</style>
