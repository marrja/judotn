---
/** Editorial section pages authored as Markdown in src/content/pages/. */
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { langParam } from '../../i18n/index.ts';
import { keyOf, localeOf } from '../../lib/content.ts';

export async function getStaticPaths() {
  const pages = await getCollection('pages', ({ data }) => !data.draft);
  // One route per page per language: the entry's own id carries both.
  return pages.map((entry) => ({
    params: { lang: langParam(localeOf(entry)), page: keyOf(entry) },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<'pages'> };
const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <PageHeader title={entry.data.title} />
  <section class="section">
    <div class="container">
      <div class="prose"><Content /></div>
    </div>
  </section>
</BaseLayout>
