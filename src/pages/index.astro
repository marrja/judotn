---
/**
 * Root language gate. This is the only page served un-prefixed; it detects the
 * visitor's browser language and redirects to `/fr/`, `/en/` or `/ar/`, falling
 * back to English. It carries no shared chrome (Header/Footer assume a locale),
 * just enough markup to redirect and to let a no-JS visitor choose.
 *
 * `noindex`: search engines index the three language homes directly (each
 * carries the hreflang cluster); this redirector should not compete with them.
 */
import { BCP47, LOCALE_NAMES, LOCALES, localePath, FALLBACK_LOCALE, DIR } from '../i18n/index.ts';
import { SITE } from '../site.js';

const alternates = LOCALES.map((lang) => ({
  lang,
  dir: DIR[lang],
  href: localePath(lang, '/'),
  name: LOCALE_NAMES[lang],
  hreflang: BCP47[lang],
}));
const fallbackHome = localePath(FALLBACK_LOCALE, '/');
---

<!doctype html>
<html lang={BCP47[FALLBACK_LOCALE]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, follow" />
    <title>{SITE.url.replace('https://', '')} — Fédération Tunisienne de Judo</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    <link rel="alternate" hreflang="x-default" href={fallbackHome} />
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: #0e0e10;
        color: #f2f0ed;
        font-family:
          system-ui,
          -apple-system,
          'Segoe UI',
          sans-serif;
        text-align: center;
        padding: 2rem;
      }
      .brand {
        font-weight: 800;
        letter-spacing: 0.02em;
        margin-bottom: 1.5rem;
      }
      p {
        color: #8f8b86;
        margin: 0 0 1.5rem;
      }
      ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        gap: 0.5rem;
        justify-content: center;
        flex-wrap: wrap;
      }
      a {
        display: block;
        padding: 0.7rem 1.4rem;
        border: 1px solid #3a3a42;
        color: #f2f0ed;
        text-decoration: none;
        font-weight: 700;
      }
      a:hover {
        border-color: #ff3b52;
        color: #ff3b52;
      }
    </style>
  </head>
  <body>
    <div>
      <div class="brand">Fédération Tunisienne de Judo</div>
      <p>Choisissez une langue · Choose a language · اختر لغة</p>
      <ul>
        {
          alternates.map((a) => (
            <li>
              <a href={a.href} hreflang={a.hreflang} lang={a.hreflang} dir={a.dir}>
                {a.name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <script>
      // Redirect to the best language match before paint where possible. The
      // chooser above stays as the no-JS fallback. `replace` so the gate does
      // not sit in the back-button history.
      import { pickLocale } from '../i18n/detect.ts';
      const langs =
        navigator.languages && navigator.languages.length
          ? navigator.languages
          : [navigator.language];
      location.replace('/' + pickLocale(langs) + '/');
    </script>
  </body>
</html>
