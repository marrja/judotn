---
/** Editorial section pages authored as Markdown in src/content/pages/. */
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages', ({ data }) => !data.draft);
  return pages.map((entry) => ({ params: { page: entry.id }, props: { entry } }));
}

type Props = { entry: CollectionEntry<'pages'> };
const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <PageHeader title={entry.data.title} crumbs={[{ label: 'Accueil', href: '/' }]} />
  <section class="section">
    <div class="container">
      <div class="prose"><Content /></div>
    </div>
  </section>
</BaseLayout>
