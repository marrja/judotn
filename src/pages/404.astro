---
/**
 * Single 404 page, in French, served at the root.
 *
 * Apache/LiteSpeed takes exactly one `ErrorDocument` path, so there is no way
 * to serve a per-language 404 from static hosting. It therefore leads with the
 * default language and offers all three home pages, so a reader who arrived on
 * a bad /en/ or /ar/ URL is one click from their own language.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { primaryNav } from '../navigation.ts';
import {
  DEFAULT_LOCALE,
  LOCALE_NAMES,
  LOCALES,
  localePath,
  useTranslations,
} from '../i18n/index.ts';
import { BCP47 } from '../i18n/ui.ts';

const t = useTranslations(DEFAULT_LOCALE);
---

<BaseLayout title={t('notFound.title')} description={t('notFound.description')} noindex>
  <section class="section wrap">
    <div class="container">
      <p class="eyebrow">{t('notFound.eyebrow')}</p>
      <h1>{t('notFound.title')}</h1>
      <p class="lede">{t('notFound.lede')}</p>

      <nav aria-label={t('a11y.mainSections')}>
        <ul>
          {
            primaryNav(DEFAULT_LOCALE).map((i) => (
              <li>
                <a href={i.href}>{i.label}</a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="actions">
        <a class="home" href={localePath(DEFAULT_LOCALE, '/')}>{t('notFound.home')}</a>
        <ul class="langs">
          {
            LOCALES.filter((l) => l !== DEFAULT_LOCALE).map((l) => (
              <li>
                <a href={localePath(l, '/')} hreflang={BCP47[l]} lang={BCP47[l]}>
                  {LOCALE_NAMES[l]}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .wrap {
    padding-block: clamp(4rem, 12vw, 8rem);
    position: relative;
    overflow: hidden;
  }
  .wrap::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 90% at 75% 20%, #e0243f24, transparent 70%);
  }
  .container {
    position: relative;
  }
  h1 {
    font-size: var(--step-4);
    text-transform: uppercase;
    letter-spacing: -0.04em;
    margin-block: var(--sp-4) var(--sp-5);
  }
  .lede {
    color: var(--mute);
    font-size: var(--step-1);
    font-family: var(--font-serif);
  }
  nav ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-block: var(--sp-6);
  }
  nav a {
    display: block;
    border: 1px solid var(--line-strong);
    padding: 0.6rem 1rem;
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: none;
  }
  nav a:hover {
    border-color: var(--accent-text);
    color: var(--accent-text);
  }
  .actions {
    display: flex;
    align-items: center;
    gap: var(--sp-5);
    flex-wrap: wrap;
  }
  .home {
    display: inline-block;
    background: var(--fg);
    color: var(--bg);
    padding: 0.95rem 1.7rem;
    font-weight: 800;
    font-size: 0.83rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
  }
  .home:hover {
    background: var(--accent);
    color: var(--accent-ink);
  }
  .langs {
    display: flex;
    gap: var(--sp-4);
    list-style: none;
  }
  .langs a {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--mute);
    text-underline-offset: 4px;
  }
  .langs a:hover {
    color: var(--fg);
  }
</style>
