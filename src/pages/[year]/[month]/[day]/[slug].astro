---
/**
 * Rebuilds the original WordPress permalink structure:
 *   /%year%/%monthnum%/%day%/%postname%/
 *
 * Both collections live in this URL space because WordPress stored documents
 * as ordinary posts in a "Documents" category. Paths come from each entry's
 * `legacyUrl`, so a slug can never silently drift away from its old address.
 */
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { formatDate, formatBytes } from '../../../../lib/format';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const documents = await getCollection('documents');

  const toPath = (entry: CollectionEntry<'posts'> | CollectionEntry<'documents'>) => {
    const [, year, month, day] = entry.data.legacyUrl.split('/');
    return { params: { year, month, day, slug: entry.data.legacySlug }, props: { entry } };
  };

  return [...posts, ...documents].map(toPath);
}

type Props = { entry: CollectionEntry<'posts'> | CollectionEntry<'documents'> };
const { entry } = Astro.props;
const { Content } = await render(entry);

// Narrow once here rather than casting inside the template: the Astro compiler
// parses `<'posts'>` in markup as Fragment shorthand and errors out.
const doc = entry.collection === 'documents' ? entry : null;
const post = entry.collection === 'posts' ? entry : null;

const description = doc
  ? `${doc.data.title} — document officiel de la Fédération Tunisienne de Judo, à télécharger au format PDF.`
  : `${entry.data.title} — Fédération Tunisienne de Judo.`;
---

<BaseLayout title={entry.data.title} {description} type="article" publishedAt={entry.data.date}>
  <article class="section">
    <div class="container">
      <nav class="crumbs" aria-label="Fil d'Ariane">
        <ol>
          <li><a href="/">Accueil</a></li>
          <li>
            <a href={doc ? '/documents/' : '/actualites/'}>
              {doc ? 'Documents' : 'Actualités'}
            </a>
          </li>
        </ol>
      </nav>

      <header>
        <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
        <h1>{entry.data.title}</h1>
      </header>

      {
        post?.data.cover && (
          <Image
            src={post.data.cover}
            alt={post.data.coverAlt}
            widths={[480, 800, 1200]}
            sizes="(max-width: 780px) 100vw, 780px"
            loading="eager"
            class="cover"
          />
        )
      }

      <div class="prose"><Content /></div>

      {
        doc && (
          <div class="dl">
            <a class="btn" href={doc.data.pdf} download>
              Télécharger le PDF
              <span>{formatBytes(doc.data.pdfBytes)}</span>
            </a>
            <p class="hint">
              Le document s'ouvre dans le lecteur PDF de votre navigateur ou de votre appareil.
            </p>

            {/*
              The preview loads on demand. Embedding the <object> directly would
              pull the whole PDF on every page view -- up to 10 Mo for the FIJ
              refereeing rules -- which is the entire page weight on mobile data.
            */}
            <div class="preview" data-pdf={doc.data.pdf} data-label={doc.data.title}>
              <button type="button">
                Afficher l'aperçu
                <span>{formatBytes(doc.data.pdfBytes)}</span>
              </button>
            </div>
          </div>
        )
      }

      {
        post && post.data.tags.length > 0 && (
          <ul class="tags">
            {post.data.tags.map((t) => (
              <li>{t}</li>
            ))}
          </ul>
        )
      }
    </div>
  </article>
</BaseLayout>

<script>
  // Swap the button for the real embed only when asked for.
  const box = document.querySelector<HTMLElement>('.preview');
  box?.querySelector('button')?.addEventListener('click', () => {
    const url = box.dataset.pdf;
    if (!url) return;
    const obj = document.createElement('object');
    obj.data = url;
    obj.type = 'application/pdf';
    obj.setAttribute('aria-label', `Aperçu de ${box.dataset.label ?? 'document'}`);
    const fallback = document.createElement('p');
    fallback.innerHTML = `Votre navigateur ne peut pas afficher ce PDF. <a href="${url}">Téléchargez-le</a>.`;
    obj.append(fallback);
    box.replaceChildren(obj);
  });
</script>

<style>
  .container {
    max-width: 860px;
  }
  .crumbs ol {
    display: flex;
    gap: var(--sp-2);
    list-style: none;
    font-size: var(--step--1);
    color: var(--mute);
    margin-bottom: var(--sp-5);
  }
  .crumbs li + li::before {
    content: '/';
    margin-right: var(--sp-2);
    color: var(--line-strong);
  }
  .crumbs a {
    text-decoration: none;
  }
  .crumbs a:hover {
    color: var(--accent-text);
  }
  header time {
    display: block;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-text);
    margin-bottom: var(--sp-3);
  }
  h1 {
    font-size: var(--step-3);
    letter-spacing: -0.035em;
  }
  .cover {
    width: 100%;
    height: auto;
    margin-block: var(--sp-6);
    border: 1px solid var(--line);
  }
  .prose {
    margin-top: var(--sp-6);
  }

  .dl {
    margin-top: var(--sp-6);
  }
  .btn {
    display: inline-flex;
    align-items: baseline;
    gap: var(--sp-3);
    background: var(--fg);
    color: var(--bg);
    padding: 0.95rem 1.7rem;
    font-weight: 800;
    font-size: 0.83rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
  }
  .btn:hover {
    background: var(--accent);
    color: var(--accent-ink);
  }
  .btn span {
    font-weight: 600;
    opacity: 0.65;
    letter-spacing: 0;
    text-transform: none;
  }
  .hint {
    font-size: var(--step--1);
    color: var(--mute);
    margin-top: var(--sp-3);
  }
  .preview {
    margin-top: var(--sp-5);
  }
  .preview button {
    font: inherit;
    display: inline-flex;
    align-items: baseline;
    gap: var(--sp-3);
    padding: 0.8rem 1.4rem;
    background: transparent;
    border: 1.5px solid var(--line-strong);
    color: inherit;
    font-weight: 800;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .preview button:hover {
    border-color: var(--accent-text);
    color: var(--accent-text);
  }
  .preview button span {
    font-weight: 600;
    letter-spacing: 0;
    text-transform: none;
    color: var(--mute);
  }
  .preview object {
    display: block;
    width: 100%;
    height: min(80vh, 900px);
    border: 1px solid var(--line);
    background: var(--surface);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    list-style: none;
    margin-top: var(--sp-6);
  }
  .tags li {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mute);
    border: 1px solid var(--line-strong);
    padding: 0.3rem 0.7rem;
  }
</style>
