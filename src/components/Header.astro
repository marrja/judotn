---
import { primaryNav, utilityNav } from '../navigation.ts';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { localePath, stripLocale, useTranslations } from '../i18n/index.ts';

const { lang } = stripLocale(Astro.url.pathname);
const t = useTranslations(lang);
const home = localePath(lang, '/');

const path = Astro.url.pathname;
const isCurrent = (href: string) => path === href || (href !== home && path.startsWith(href));

const primary = primaryNav(lang);
const utility = utilityNav(lang);
---

<div class="utility">
  <div class="container row">
    <span class="tagline">{t('site.tagline')}</span>
    <nav class="util-nav" aria-label={t('a11y.navSecondary')}>
      <ul>
        {
          utility.map((i) => (
            <li>
              <a href={i.href}>{i.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
    <LanguageSwitcher />
  </div>
</div>

<header>
  <div class="container bar">
    <a class="brand" href={home}>
      <img src="/logo-judo-dark.png" alt="" width="46" height="45" />
      <span>
        <b>{t('site.title')}</b>
        <i>{t('site.shortTitle')}</i>
      </span>
    </a>

    <nav class="primary" id="primary-nav" aria-label={t('a11y.navPrimary')}>
      <ul>
        {
          primary.map((item) => (
            <li class={item.children ? 'has-sub' : ''}>
              <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
              {item.children && (
                <ul class="sub">
                  {item.children.map((c) => (
                    <li>
                      <a
                        href={c.href}
                        rel={c.external ? 'noopener noreferrer' : undefined}
                        target={c.external ? '_blank' : undefined}
                      >
                        {c.label}
                        {c.external && <span aria-label={t('a11y.externalLink')}>↗</span>}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))
        }
      </ul>
    </nav>

    <button type="button" id="nav-toggle" aria-expanded="false" aria-controls="primary-nav">
      <span class="sr">{t('a11y.menu')}</span>
      <i aria-hidden="true"></i>
    </button>
  </div>
</header>

<script>
  const btn = document.getElementById('nav-toggle');
  const nav = document.getElementById('primary-nav');
  btn?.addEventListener('click', () => {
    const open = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!open));
    nav?.classList.toggle('open', !open);
  });
</script>

<style>
  /* Navs are selected by class, never by aria-label: those labels are
     translated, so an attribute selector would only match the French build. */
  .utility {
    border-bottom: 1px solid var(--line);
    font-size: var(--step--1);
    color: var(--mute);
  }
  .row {
    display: flex;
    align-items: center;
    gap: var(--sp-5);
    min-height: 40px;
    flex-wrap: wrap;
  }
  .utility ul {
    display: flex;
    gap: var(--sp-5);
    list-style: none;
  }
  .util-nav {
    margin-inline-start: auto;
  }
  .utility a {
    text-decoration: none;
  }
  .utility a:hover {
    color: var(--fg);
  }

  header {
    border-bottom: 1px solid var(--line);
    position: relative;
  }
  .bar {
    display: flex;
    align-items: center;
    gap: var(--sp-5);
    padding-block: var(--sp-3);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    text-decoration: none;
  }
  .brand b {
    display: block;
    font-size: 0.98rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }
  .brand i {
    display: block;
    font-style: normal;
    font-size: 0.63rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--accent-text);
  }

  .primary {
    margin-inline-start: auto;
  }
  .primary > ul {
    display: flex;
    gap: 0.1rem;
    list-style: none;
  }
  .primary a {
    display: block;
    font-size: 0.79rem;
    font-weight: 700;
    padding: var(--sp-3);
    text-decoration: none;
    position: relative;
    white-space: nowrap;
  }
  .primary > ul > li > a::after {
    content: '';
    position: absolute;
    inset-inline: var(--sp-3);
    bottom: 0.4rem;
    height: 2px;
    background: var(--accent-text);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.22s;
  }
  /* transform-origin takes no logical keyword, so the RTL build flips it by
     hand — otherwise the underline would grow away from the text. */
  :global([dir='rtl']) .primary > ul > li > a::after {
    transform-origin: right;
  }
  .primary > ul > li > a:hover::after,
  .primary a[aria-current='page']::after {
    transform: scaleX(1);
  }

  .sub {
    position: absolute;
    list-style: none;
    background: var(--surface);
    border: 1px solid var(--line-strong);
    min-width: 240px;
    padding: var(--sp-2) 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: 0.18s;
    z-index: 20;
  }
  .has-sub:hover .sub,
  .has-sub:focus-within .sub {
    opacity: 1;
    visibility: visible;
    transform: none;
  }
  .sub a {
    font-weight: 600;
    padding-inline: var(--sp-4);
    white-space: normal;
  }
  .sub a:hover {
    color: var(--accent-text);
  }
  .sub span {
    font-size: 0.7em;
    opacity: 0.6;
    margin-inline-start: 0.3em;
  }

  #nav-toggle {
    display: none;
    margin-inline-start: auto;
    width: 42px;
    height: 42px;
    place-items: center;
    background: transparent;
    border: 1px solid var(--line-strong);
    color: inherit;
    cursor: pointer;
  }
  #nav-toggle i,
  #nav-toggle i::before,
  #nav-toggle i::after {
    display: block;
    width: 18px;
    height: 1.5px;
    background: currentColor;
    position: relative;
  }
  #nav-toggle i::before,
  #nav-toggle i::after {
    content: '';
    position: absolute;
    inset-inline-start: 0;
  }
  #nav-toggle i::before {
    top: -5px;
  }
  #nav-toggle i::after {
    top: 5px;
  }
  .sr {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
  }

  @media (max-width: 1080px) {
    .util-nav {
      display: none;
    }
    #nav-toggle {
      display: grid;
    }
    .primary {
      display: none;
      width: 100%;
      order: 3;
    }
    .primary.open {
      display: block;
      padding-bottom: var(--sp-4);
    }
    .primary > ul {
      flex-direction: column;
      gap: 0;
    }
    .primary > ul > li {
      border-top: 1px solid var(--line);
    }
    .primary a {
      padding: var(--sp-3) 0;
      font-size: 0.95rem;
    }
    .sub {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      border: 0;
      background: transparent;
      padding: 0 0 var(--sp-3);
      padding-inline-start: var(--sp-4);
      min-width: 0;
    }
    .sub a {
      padding-inline: 0;
      font-size: 0.85rem;
      color: var(--mute);
    }
  }
</style>
