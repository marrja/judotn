---
import { localePath, stripLocale, useTranslations } from '../i18n/index.ts';

interface Props {
  title: string;
  intro?: string;
  /**
   * Breadcrumbs BETWEEN the home page and this one, excluding both. The home
   * crumb is prepended automatically — every caller wanted it, and having each
   * one translate "Accueil" itself was four copies of the same three lines.
   */
  crumbs?: { label: string; href: string }[];
}
const { title, intro, crumbs = [] } = Astro.props;

const { lang } = stripLocale(Astro.url.pathname);
const t = useTranslations(lang);
const trail = [{ label: t('nav.home'), href: localePath(lang, '/') }, ...crumbs];
---

<div class="page-header">
  <div class="container">
    <nav class="crumbs" aria-label={t('a11y.breadcrumb')}>
      <ol>
        {
          trail.map((c) => (
            <li>
              <a href={c.href}>{c.label}</a>
            </li>
          ))
        }
        <li aria-current="page">{title}</li>
      </ol>
    </nav>
    <h1>{title}</h1>
    {intro && <p class="intro">{intro}</p>}
  </div>
</div>

<style>
  .page-header {
    border-bottom: 1px solid var(--line);
    position: relative;
    overflow: hidden;
  }
  .page-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 100% at 85% 50%, #e0243f24, transparent 70%);
  }
  .container {
    position: relative;
    padding-block: clamp(2.4rem, 6vw, 4rem);
  }
  .crumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    list-style: none;
    font-size: var(--step--1);
    color: var(--mute);
    margin-bottom: var(--sp-4);
  }
  .crumbs li + li::before {
    content: '/';
    margin-inline-end: var(--sp-2);
    color: var(--line-strong);
  }
  .crumbs a {
    text-decoration: none;
  }
  .crumbs a:hover {
    color: var(--accent-text);
  }
  h1 {
    font-size: var(--step-4);
    text-transform: uppercase;
    letter-spacing: -0.04em;
  }
  .intro {
    color: var(--mute);
    margin-top: var(--sp-4);
    max-width: 56ch;
  }
</style>
