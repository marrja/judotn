---
import { primaryNav, usefulLinks, olympicLinks } from '../navigation.ts';
import { localePath, stripLocale, useTranslations } from '../i18n/index.ts';

const { lang } = stripLocale(Astro.url.pathname);
const t = useTranslations(lang);
const at = (path: string) => localePath(lang, path);

// Documents and news have their own columns elsewhere on the page, so the
// federation column drops them. Compared against localised hrefs, since every
// internal nav href is prefixed for the current language.
const listed = [at('/documents/'), at('/actualites/')];
const federation = primaryNav(lang).filter((i) => !listed.includes(i.href));
const year = new Date().getFullYear();

const columns = [
  { title: t('footer.federation'), items: federation },
  { title: t('footer.usefulLinks'), items: usefulLinks(lang) },
  { title: t('footer.olympism'), items: olympicLinks(lang) },
];
---

<footer>
  <div class="container">
    <div class="grid">
      <div>
        <div class="brand">
          <img src="/logo-judo-dark.png" alt="" width="46" height="45" />
          <b>{t('site.title')}</b>
        </div>
        <p>{t('site.footerBlurb')}</p>
        <a class="feed" href={at('/rss.xml')}>{t('footer.rss')}</a>
      </div>

      {
        columns.map((col) => (
          <nav aria-label={col.title}>
            <h2>{col.title}</h2>
            <ul>
              {col.items.map((i) => (
                <li>
                  <a
                    href={i.href}
                    rel={i.external ? 'noopener noreferrer' : undefined}
                    target={i.external ? '_blank' : undefined}
                  >
                    {i.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <div class="bottom">
      <span>© {year} {t('site.title')}</span>
      <a href={at('/contact/')}>{t('nav.contact')}</a>
      <span>judo.tn</span>
    </div>
  </div>
</footer>

<style>
  footer {
    /* footer sits on a darker ground than --bg, so the muted tone is
       lifted here to keep small legal text at WCAG AA (4.58:1). */
    --legal: #7d7975;
    border-top: 1px solid var(--line);
    background: #0a0a0c;
    padding-block: var(--sp-7) var(--sp-5);
    margin-top: var(--sp-8);
  }
  .grid {
    display: grid;
    grid-template-columns: 1.5fr repeat(3, 1fr);
    gap: var(--sp-6);
  }
  .brand {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-bottom: var(--sp-4);
  }
  .brand b {
    font-size: 0.95rem;
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.02em;
    max-width: 16ch;
  }
  p {
    font-size: 0.86rem;
    color: var(--mute);
    max-width: 34ch;
  }
  h2 {
    font-size: 0.68rem;
    letter-spacing: 0.17em;
    text-transform: uppercase;
    color: var(--accent-text);
    margin: 0 0 var(--sp-4);
    font-weight: 800;
  }
  ul {
    list-style: none;
  }
  li {
    margin-bottom: var(--sp-2);
  }
  li a,
  .feed {
    font-size: 0.84rem;
    color: var(--mute);
    text-decoration: none;
  }
  li a:hover,
  .feed:hover {
    color: var(--fg);
  }
  .feed {
    display: inline-block;
    margin-top: var(--sp-3);
    border-bottom: 1px solid var(--line-strong);
    padding-bottom: 2px;
  }
  .bottom {
    margin-top: var(--sp-7);
    padding-top: var(--sp-4);
    border-top: 1px solid var(--line);
    display: flex;
    gap: var(--sp-4);
    flex-wrap: wrap;
    font-size: 0.75rem;
    color: var(--legal);
  }
  .bottom a {
    color: inherit;
  }
  .bottom a:hover {
    color: var(--fg);
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
