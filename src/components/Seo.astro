---
import {
  alternates,
  BCP47,
  FALLBACK_LOCALE,
  localePath,
  stripLocale,
  useTranslations,
} from '../i18n/index.ts';

interface Props {
  title: string;
  description: string;
  /** Absolute or root-relative image path for og:image. */
  image?: string;
  /** Overrides the canonical derived from Astro.url. */
  canonical?: string;
  type?: 'website' | 'article';
  publishedAt?: Date;
  noindex?: boolean;
  /** Page-specific JSON-LD node(s), merged into the sitewide @graph. */
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  image = '/logo-judo.png',
  canonical,
  type = 'website',
  publishedAt,
  noindex = false,
  schema,
} = Astro.props;

const { lang } = stripLocale(Astro.url.pathname);
const t = useTranslations(lang);

// Yoast stored no titles or descriptions for any page (every row was empty),
// so these are authored fresh rather than migrated.
const siteTitle = t('site.title');
const fullTitle = title === siteTitle ? title : `${title} — ${t('site.shortTitle')}`;
const url = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;

// The sitemap integration emits hreflang too, but search engines read the
// in-page tags for pages they reach directly, so both are needed.
const langAlternates = alternates(Astro.url.pathname).map((a) => ({
  hreflang: BCP47[a.lang],
  href: new URL(a.href, Astro.site).href,
}));
/** x-default points at the English version — the site's declared fallback. */
const { path: canonicalPath } = stripLocale(Astro.url.pathname);
const xDefault = new URL(localePath(FALLBACK_LOCALE, canonicalPath), Astro.site).href;

// Structured data. The organization node is emitted on every page so any page
// is a self-describing, citable entry point for search and AI engines; routes
// pass page-specific nodes (Article, BreadcrumbList) via `schema`. `@id` is
// constant so all nodes across the site resolve to one organization entity.
const orgId = new URL('#organization', Astro.site).href;
const organization = {
  '@type': 'SportsOrganization',
  '@id': orgId,
  name: siteTitle,
  url: new URL(localePath(lang, '/'), Astro.site).href,
  logo: new URL('/logo-judo.png', Astro.site).href,
  sport: 'Judo',
  sameAs: ['https://www.tunisie-judo.org/'],
};
const graph = [organization, ...(Array.isArray(schema) ? schema : schema ? [schema] : [])];
// Escape `<` so a title containing "</script>" cannot break out of the tag.
const jsonLd = JSON.stringify({ '@context': 'https://schema.org', '@graph': graph }).replace(
  /</g,
  '\\u003c',
);
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={url} />
{noindex && <meta name="robots" content="noindex, follow" />}

{
  /* A noindex page (the single, French-only 404) has no locale variants to
     advertise — emitting hreflang for /en/404/ etc. would point at routes that
     do not exist. */
  !noindex && (
    <>
      {langAlternates.map((a) => (
        <link rel="alternate" hreflang={a.hreflang} href={a.href} />
      ))}
      <link rel="alternate" hreflang="x-default" href={xDefault} />
    </>
  )
}

<meta property="og:type" content={type} />
<meta property="og:site_name" content={siteTitle} />
<meta property="og:locale" content={BCP47[lang].replace('-', '_')} />
{
  alternates(Astro.url.pathname)
    .filter((a) => a.lang !== lang)
    .map((a) => <meta property="og:locale:alternate" content={BCP47[a.lang].replace('-', '_')} />)
}
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={url} />
<meta property="og:image" content={ogImage} />
{publishedAt && <meta property="article:published_time" content={publishedAt.toISOString()} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<script type="application/ld+json" is:inline set:html={jsonLd} />
