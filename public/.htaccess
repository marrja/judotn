# Generated from src/redirects.json — do not edit by hand.
# Hostinger / LiteSpeed (Apache-compatible).

Options -Indexes
DirectoryIndex index.html

# Serve the custom 404 page for anything that does not exist.
# Deleted AATUJA pages (/about-us/, /members-board/, /sample-page/*) land here
# by design — they are gone, not moved.
ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS. %{HTTP_HOST} rather than a literal domain so this also works on
  # Hostinger's temporary preview subdomain; the X-Forwarded-Proto check avoids
  # a redirect loop when TLS is terminated upstream.
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !=https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # Drop the www subdomain.
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]
</IfModule>

# ── Redirects from the old WordPress site ─────────────────────────────
RedirectMatch 301 ^/elementor-314/?$ /
RedirectMatch 301 ^/category/news/?$ /fr/actualites/
RedirectMatch 301 ^/category/announcements/?$ /fr/actualites/
RedirectMatch 301 ^/category/documents/?$ /fr/documents/
RedirectMatch 301 ^/feed/?$ /fr/rss.xml
RedirectMatch 301 ^/wp-content/uploads/2024/06/(.+)\.pdf$ /documents/$1.pdf

# ── French moved from the root to /fr/ ────────────────────────────────
# Every URL that used to serve French content at the root now 301s to its
# /fr/ counterpart, so no inbound link or bookmark breaks. Generated from the
# current French content — deleted pages are absent and 404 as intended.
RedirectMatch 301 ^/2023/10/16/accueil-de-lentraineur-japonais-izuru-tschiya-7e-dan-kendo-pour-participer-a-lencadrement-du-kendo-tunisien-pendant-2-ans/?$ /fr/2023/10/16/accueil-de-lentraineur-japonais-izuru-tschiya-7e-dan-kendo-pour-participer-a-lencadrement-du-kendo-tunisien-pendant-2-ans/
RedirectMatch 301 ^/2023/10/16/accueil-de-lentraineur-japonais-taiga-moro-pour-participer-a-lencadrement-des-sessions-dentrainement-des-equipes-nationales-pendant-6-mois/?$ /fr/2023/10/16/accueil-de-lentraineur-japonais-taiga-moro-pour-participer-a-lencadrement-des-sessions-dentrainement-des-equipes-nationales-pendant-6-mois/
